# Copy this file to `.env` before running the app.
# Never commit real API keys.

# Server
DIALECT_SERVICE_HOST=0.0.0.0
DIALECT_SERVICE_PORT=7860
# Required for real ASR and voice enrollment because DashScope must fetch uploaded audio.
# Use a public HTTP/HTTPS origin in production, for example: https://your-domain.example
PUBLIC_BASE_URL=
CORS_ALLOW_ORIGINS=*

# DashScope / Qwen credentials
DASHSCOPE_API_KEY=
QWEN_LLM_API_KEY=

# ASR
ASR_PROVIDER=dashscope_paraformer
ASR_MODEL=paraformer-v2
ASR_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/audio/asr/transcription
DASHSCOPE_TASK_URL=https://dashscope.aliyuncs.com/api/v1/tasks

# LLM for punctuation, emotion/prosody analysis, and dialect rewriting
# IMPORTANT: qwen-plus / qwen-max will be DEPRECATED 2026-07-13.
# Use qwen3.7-max (newest flagship) or qwen3.6-plus (cost/quality balance).
QWEN_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_LLM_MODEL=qwen3.7-max

# CosyVoice TTS
# Gold Teacher: cosyvoice-v3-plus (system voice + instruction control)
# Voice Matched: cosyvoice-v3.5-plus (strongest cloning, Beijing only, NO system voices)
TTS_PROVIDER=dashscope_cosyvoice
QWEN_TTS_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_TTS_MODEL=cosyvoice-v3-plus
QWEN_TTS_VOICE=longanyang

# Voice enrollment and cloned voice synthesis
VOICE_MATCH_PROVIDER=cosyvoice_clone
QWEN_VOICE_ENROLLMENT_MODEL=voice-enrollment
QWEN_VOICE_TARGET_MODEL=cosyvoice-v3.5-plus
QWEN_VOICE_ENROLLMENT_URL=https://dashscope.aliyuncs.com/api/v1/services/audio/tts/customization
QWEN_VOICE_CACHE_DIR=

# Runtime limits
MAX_UPLOAD_MB=30
CLEANUP_AFTER_HOURS=24
VOICE_CACHE_TTL_HOURS=720
API_REQUEST_TIMEOUT_S=90
API_MAX_RETRIES=3
SPEAKER_REF_AUDIO_MIN_S=10
SPEAKER_REF_AUDIO_MAX_S=20

# Local/demo mode. Set to 1 only for UI tests without real provider calls.
ENABLE_MOCK_WHEN_NO_KEY=0
